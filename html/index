<!DOCTYPE html>
<html>
<head>
    <title>Hospital Management System</title>
    <link rel="stylesheet" href="xyz.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>

<nav class="navbar">
    <div class="nav-brand">
        <i class="fas fa-hospital"></i> HOSPITAL MANAGEMENT SYSTEM
    </div>
    <div class="nav-links">
        <a href="#"><i class="fas fa-home"></i> Dashboard</a>
        <a href="#" class="active"><i class="fas fa-user-plus"></i> New Patient</a>
        <a href="#"><i class="fas fa-history"></i> Records</a>
    </div>
</nav>

<div class="container">
    <h1><i class="fas fa-file-medical"></i> Patient Registration</h1>
    
    <form action="save_record.php" method="post" enctype="multipart/form-data">

        <!-- Patient Information Card -->
        <div class="card">
            <h2><i class="fas fa-user-injured"></i> Patient Information</h2>
            <div class="row">
                <div class="input-box">
                    <label><i class="fas fa-id-card"></i> Patient ID</label>
                    <input type="text" name="patient_id" placeholder="Auto-generated" readonly>
                </div>
                <div class="input-box">
                    <label><i class="fas fa-user"></i> Full Name *</label>
                    <input type="text" name="full_name" placeholder="Enter Full Name" required>
                </div>
            </div>
            
            <div class="row">
                <div class="input-box">
                    <label><i class="fas fa-birthday-cake"></i> Age *</label>
                    <input type="number" name="age" placeholder="Enter Age" required>
                </div>
                <div class="input-box">
                    <label><i class="fas fa-venus-mars"></i> Gender *</label>
                    <div class="gender-group">

                        <label><input type="radio" name="gender" value="Male" required> Male</label>
                        <label><input type="radio" name="gender" value="Female"> Female</label>
                        <label><input type="radio" name="gender" value="Other"> Other</label>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="input-box">
                    <b></b>
                    <label><i class="fas fa-phone"></i> Contact Number *</label>
                    <input type="tel" name="contact" placeholder="Enter Contact" required>
                </div>
                <div class="input-box">
                    <label><i class="fas fa-envelope"></i> Email</label>
                    <input type="email" name="email" placeholder="Enter Email">
                </div>
            </div>

            <div class="row">
                <div class="input-box">
                    <label><i class="fas fa-tint"></i> Blood Group</label>
                    <select name="blood_group">
                        <option value="">Select Blood Group</option>
                        <option>A+</option><option>A-</option>
                        <option>B+</option><option>B-</option>
                        <option>AB+</option><option>AB-</option>
                        <option>O+</option><option>O-</option>
                    </select>
                </div>
                <div class="input-box">
                    <label><i class="fas fa-phone-volume"></i> Emergency Contact</label>
                    <input type="tel" name="emergency_contact" placeholder="Emergency Number">
                </div>
            </div>

            <div class="input-box full-width">
                <label><i class="fas fa-map-marker-alt"></i> Address</label>
                <textarea name="address" rows="2" placeholder="Full Address"></textarea>
            </div>
        </div>

        <!-- Medical Information Card -->
        <div class="card">
            <h2><i class="fas fa-notes-medical"></i> Medical Information</h2>
            <div class="row">
                <div class="input-box">
                    <label>Height (cm)</label>
                    <input type="number" step="0.01" name="height" placeholder="170">
                </div>
                <div class="input-box">
                    <label>Weight (kg)</label>
                    <input type="number" step="0.01" name="weight" placeholder="65">
                </div>
                <div class="input-box">
                    <label>BMI</label>
                    <input type="number" step="0.01" name="bmi" placeholder="Auto-calc" readonly>
                </div>
            <div class="input-box full-width">
                <label><i class="fas fa-allergies"></i> Allergies</label>
                <textarea name="allergies" rows="2" placeholder="List any allergies"></textarea>
            </div>
            <div class="input-box full-width">
                <label><i class="fas fa-history"></i> Previous Medical History</label>
                <textarea name="previous_history" rows="3"></textarea>
            </div>
            <div class="input-box full-width">
                <label><i class="fas fa-pills"></i> Current Medications</label>
                <textarea name="current_medications" rows="2"></textarea>
            </div>
        </div>

        <!-- Diagnosis Card -->
        <div class="card">
            <h2><i class="fas fa-stethoscope"></i> Diagnosis Details</h2>
            <div class="row">
                <div class="input-box">
                    <label><i class="fas fa-calendar"></i> Visit Date *</label>
                    <input type="date" name="visit_date" required>
                </div>
                <div class="input-box">
                    <label><i class="fas fa-exclamation-triangle"></i> Severity</label>
                    <select name="severity">
                        <option>Mild</option>
                        <option>Moderate</option>
                        <option>Severe</option>
                    </select>
                </div>
            </div>
            <div class="input-box full-width">
                <label>Disease / Diagnosis</label>
                <input type="text" name="disease" placeholder="Enter Diagnosis">
            </div>
            <div class="input-box full-width">
                <label>Symptoms</label>
                <textarea name="symptoms" rows="2" placeholder="Patient symptoms"></textarea>
            </div>
            <div class="row">
                <div class="input-box">
                    <label><i class="fas fa-thermometer-half"></i> Temperature</label>
                    <input type="text" name="temperature" placeholder="98.6°F">
                </div>
                <div class="input-box">
                    <label><i class="fas fa-heartbeat"></i> Blood Pressure</label>
                    <input type="text" name="blood_pressure" placeholder="120/80">
                </div>
                <div class="input-box">
                    <label>Pulse Rate</label>
                    <input type="number" name="pulse_rate" placeholder="72 bpm">
                </div>
                <div class="input-box">
                    <label>SpO₂</label>
                    <input type="text" name="spo2" placeholder="98%">
                </div>
            </div>
        </div>

        <!-- Lab + Prescription Cards baaki same pattern mein... -->

        <div class="button-group">
            <button type="submit" class="btn-primary">
                <i class="fas fa-save"></i> Save Record
            </button>
            <button type="button" class="btn-secondary">
                <i class="fas fa-history"></i> Previous Visits
            </button>
            <button type="button" class="btn-secondary">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </form>
</div>

</body>
</html>
